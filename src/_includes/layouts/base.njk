<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="MobileOptimized" content="width" />
  <meta name="HandheldFriendly" content="true" />
  <meta name="theme-color" content="#324c31" />
  {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
  <title>{{ title }} | {{ site.fullTitle }} | CID</title>

  {# Favicons #}
  <link rel="icon" href="/assets/images/logo_fav.png" type="image/png" />
  <link rel="apple-touch-icon" href="/assets/images/logo_fav.png" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  {% if rssLink %}<link rel="alternate" type="application/rss+xml" title="{{ site.title }} Blog" href="{{ site.url }}/feed.xml" />{% endif %}

  {# Open Graph / Social sharing #}
  {% set _ogImage = ogImage if ogImage else (heroImage if heroImage else (thumbnail if thumbnail else site.defaultOgImage)) %}
  {% set _ogImageUrl = site.url + _ogImage %}
  {% set _ogDesc = description if description else site.slogan %}
  {% set _ogTitle = title + " | " + site.fullTitle %}
  <meta property="og:type" content="{{ ogType if ogType else 'website' }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:title" content="{{ _ogTitle }}" />
  <meta property="og:description" content="{{ _ogDesc }}" />
  <meta property="og:image" content="{{ _ogImageUrl }}" />
  <meta property="og:site_name" content="{{ site.fullTitle }}" />
  <meta property="og:locale" content="en_US" />
  {% if ogType == "article" %}
  {% if date %}<meta property="article:published_time" content="{{ date | htmlDateString }}" />{% endif %}
  <meta property="article:author" content="{{ site.url }}" />
  <meta property="article:section" content="Home Improvement" />
  {% endif %}

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@CIDbasements" />
  <meta name="twitter:title" content="{{ _ogTitle }}" />
  <meta name="twitter:description" content="{{ _ogDesc }}" />
  <meta name="twitter:image" content="{{ _ogImageUrl }}" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Palanquin+Dark:regular|Maitree:regular&subset=latin&display=swap" media="all" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.css" />
  <link rel="stylesheet" href="/assets/css/main.css" />

  {# LocalBusiness JSON-LD — present on every page for local SEO #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@id": "https://www.cidbasements.com/#business",
    "@type": ["HomeAndConstructionBusiness", "GeneralContractor"],
    "name": {{ site.fullTitle | toJSON | safe }},
    "alternateName": {{ site.title | toJSON | safe }},
    "url": {{ site.url | toJSON | safe }},
    "telephone": {{ ("+1" + site.phoneRaw) | toJSON | safe }},
    "email": {{ site.email | toJSON | safe }},
    "openingHours": ["Mo-Fr 08:00-17:00"],
    "priceRange": "$$",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "reviewCount": "47",
      "ratingCount": "47"
    },
    "logo": {
      "@type": "ImageObject",
      "url": {{ (site.url + "/assets/images/cid.svg") | toJSON | safe }}
    },
    "image": {{ (site.url + site.defaultOgImage) | toJSON | safe }},
    "foundingDate": {{ site.foundingDate | toJSON | safe }},
    "description": "Basement finishing and remodeling company serving Parker, Castle Rock, Aurora, and surrounding Colorado areas since 1976.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": {{ site.address.addressLocality | toJSON | safe }},
      "addressRegion": {{ site.address.addressRegion | toJSON | safe }},
      "addressCountry": {{ site.address.addressCountry | toJSON | safe }}
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": {{ site.geo.latitude }},
      "longitude": {{ site.geo.longitude }}
    },
    "areaServed": [
      {"@type": "City", "name": "Aurora"},
      {"@type": "City", "name": "Castle Rock"},
      {"@type": "City", "name": "Castle Pines"},
      {"@type": "City", "name": "Centennial"},
      {"@type": "City", "name": "Englewood"},
      {"@type": "City", "name": "Highlands Ranch"},
      {"@type": "City", "name": "Littleton"},
      {"@type": "City", "name": "Parker"}
    ],
    "hasMap": {{ site.googleMapsUrl | toJSON | safe }},
    "sameAs": [
      {{ site.social.facebook | toJSON | safe }},
      {{ site.social.youtube | toJSON | safe }},
      {{ site.social.twitter | toJSON | safe }},
      {{ site.bbb | toJSON | safe }}
    ]
  }
  </script>

  {# TODO: Migrate to GA4 — Universal Analytics (analytics.js) was sunset July 2023 #}
  <script>
    (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
    (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
    m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
    })(window,document,'script','//www.google-analytics.com/analytics.js','ga');
    ga('create', '{{ site.analytics }}', 'auto');
    ga('send', 'pageview');
  </script>
</head>
<body class="{{ bodyClass }}">
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <div class="layout-container">

    {# Top bar #}
    <div class="overhead">
      <ul class="top-links">
        <li class="email"><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        <li class="phone">{{ site.phone }}</li>
        <li class="estimate"><a href="/contact/">Free Estimate</a></li>
        <li class="login"><a href="{{ site.constructLogin }}">Client Login</a></li>
      </ul>
    </div>

    {# Header #}
    <header role="banner" class="site-header">
      <div class="site-info">
        <div class="logo">
          <a href="/" rel="home" title="Home">
            <img alt="CID Basements Logo" src="/assets/images/cid.svg" />
          </a>
        </div>
        <div class="site-text">
          <div class="site-name">{{ site.fullTitle }}</div>
          <div class="site-slogan">{{ site.slogan }}</div>
        </div>
      </div>
    </header>

    {# Navigation #}
    {% include "components/nav.njk" %}

    {# Page content — each layout injects its full structure here #}
    {{ content | safe }}

    {# Footer #}
    {% include "components/footer.njk" %}

  </div>

  <script src="https://cdn.jsdelivr.net/npm/photoswipe@5/dist/umd/photoswipe.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/photoswipe@5/dist/umd/photoswipe-lightbox.umd.min.js"></script>
  <script src="/assets/js/main.js"></script>
</body>
</html>
