---
layout: layouts/base.njk
bodyClass: "ant-one-sidebar ant-sidebar-second path-node page-node-type-page"
---
<div class="page-layout has-sidebar">
  <main role="main" id="main-content">
    <article class="page-content">
      <h1>{{ title }}</h1>
      <div class="page-body">
        {{ content | safe }}
      </div>
    </article>
  </main>
  <aside class="layout-sidebar-second" role="complementary">
    {% include "components/sidebar.njk" %}
  </aside>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": {{ (site.url + "/") | toJSON | safe }}},
    {"@type": "ListItem", "position": 2, "name": {{ title | toJSON | safe }}, "item": {{ (site.url + page.url) | toJSON | safe }}}
  ]
}
</script>
