---
layout: layouts/base.njk
title: Photos
bodyClass: "path-finished-basements"
permalink: /finished-basements/index.html
---
<main role="main" id="main-content" style="padding: 0 var(--layout-spacing); margin-bottom: 2rem;">
  <h1>{{ title }}</h1>

  <nav class="photo-type-nav" aria-label="View type">
    <ul>
      <li><a href="/finished-basements/" class="is-active" aria-current="page">Photos</a></li>
      <li><a href="/basement-videos/">Videos</a></li>
    </ul>
  </nav>

  <nav class="photo-category-nav" aria-label="Photo category">
    <h2>Photo Category</h2>
    <ul>
      <li><a href="/finished-basements/" class="is-active" aria-current="page">All</a></li>
      {% for cat in galleryCategories %}
      <li><a href="/finished-basements/{{ cat.slug }}/">{{ cat.name }}</a></li>
      {% endfor %}
    </ul>
  </nav>

  <div class="gallery-grid pswp-gallery" id="photo-gallery">
    {% for img in gallery %}
    <a href="{{ img.src }}"
       class="gallery-item"
       data-pswp-width="650"
       data-pswp-height="650">
      <img loading="lazy" src="{{ img.thumb }}" alt="{{ img.alt }}" width="300" height="250" />
    </a>
    {% endfor %}
  </div>
</main>
